{
  "name": "Weekly Dev Summary with Claude Code",
  "nodes": [
    {
      "name": "Weekly Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": {
          "interval": [
            "week"
          ],
          "hour": 9,
          "weekday": 1
        }
      }
    },
    {
      "name": "Get GitHub Activity",
      "type": "n8n-nodes-base.github",
      "parameters": {
        "operation": "getIssues",
        "repositoryOwner": "{{ $env.GITHUB_OWNER }}",
        "repositoryName": "{{ $env.GITHUB_REPO }}",
        "additionalFields": {
          "since": "{{ $('moment').subtract(7, 'days').format('YYYY-MM-DD') }}"
        }
      }
    },
    {
      "name": "Claude Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "{{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "body": {
            "contentType": "json",
            "body": "{\"model\":\"claude-3-5-sonnet-20241022\",\"max_tokens\":1000,\"system\":\"Create concise weekly dev summary from GitHub activity.\",\"messages\":[{\"role\":\"user\",\"content\":\"{{ $json.summary }}\"}]}"
          }
        }
      }
    },
    {
      "name": "Send to Slack",
      "type": "n8n-nodes-base.slack",
      "parameters": {
        "channel": "{{ $env.SLACK_CHANNEL }}",
        "text": "Weekly Summary: {{ $json.metrics.week }}\\n{{ $json.claudeResponse }}"
      }
    }
  ]
}